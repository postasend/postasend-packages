{
  "name": "postasend",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the PostaSend email API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "postasend",
    "email",
    "transactional",
    "sdk"
  ],
  "author": "PostaSend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/postasend/postasend-node"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
